# Catch-all for unknown hosts on port 443.
server {
	listen 443 ssl default_server;
	listen [::]:443 ssl default_server;
	server_name _;

	# Any valid cert can be used for catch-all TLS handshake.
	ssl_certificate /etc/letsencrypt/live/server.faceblurr.com/fullchain.pem;
	ssl_certificate_key /etc/letsencrypt/live/server.faceblurr.com/privkey.pem;
	include /etc/letsencrypt/options-ssl-nginx.conf;
	ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

	return 444;
}