## Multi-site default for test VPS
## Host routing:
## - server.key-ching.com    -> 127.0.0.1:2999
## - server.faceblurr.com   -> 127.0.0.1:3000 (plus /py -> 127.0.0.1:5000)
## - server.prolifer8.com     -> 127.0.0.1:4000
## - server.iota-chat.com    -> 127.0.0.1:5000

# HTTP -> HTTPS redirect for all configured hosts.
server {
	listen 80;
	listen [::]:80;
	server_name server.key-ching.com server.faceblurr.com server.prolifer8.com server.iota-chat.com;
	return 301 https://$host$request_uri;
}

# Catch-all for unknown hosts on port 80.
server {
	listen 80 default_server;
	listen [::]:80 default_server;
	server_name _;
	return 444;
}

server {
	listen 443 ssl http2;
	listen [::]:443 ssl http2;
	server_name server.key-ching.com;

	ssl_certificate /etc/letsencrypt/live/server.key-ching.com/fullchain.pem;
	ssl_certificate_key /etc/letsencrypt/live/server.key-ching.com/privkey.pem;
	include /etc/letsencrypt/options-ssl-nginx.conf;
	ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

	client_max_body_size 500M;
	client_body_timeout 300s;
	proxy_connect_timeout 300s;
	proxy_send_timeout 300s;
	proxy_read_timeout 300s;
	send_timeout 300s;

	location / {
		proxy_pass http://127.0.0.1:2999;
		proxy_http_version 1.1;
		proxy_set_header Upgrade $http_upgrade;
		proxy_set_header Connection "upgrade";
		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header X-Forwarded-Proto $scheme;
		proxy_request_buffering off;
		proxy_buffering off;
	}
}

